{
	"name": "localart-canvas",
	"version": "0.0.0",
	"description": "A local-first AI visual canvas powered by tldraw, Ollama and ComfyUI.",
	"private": true,
	"homepage": "https://github.com/planedob/localart-canvas",
	"license": "MIT",
	"author": "LocalArt Canvas contributors",
	"config": {
		"forge": "./forge.config.cjs"
	},
	"engines": {
		"node": ">=22.15.0"
	},
	"type": "module",
	"main": ".desktop/main.cjs",
	"scripts": {
		"build": "vite build && npm run build:desktop && npm run typecheck",
		"build:desktop": "node scripts/build-desktop.mjs",
		"dev": "concurrently -k -n server,client \"npm:dev:server\" \"npm:dev:client\"",
		"dev:client": "vite --host 127.0.0.1",
		"dev:desktop": "npm run build:desktop && electron .",
		"dev:server": "tsx watch server/index.ts",
		"make": "npm run build && electron-forge make",
		"package": "npm run build && electron-forge package",
		"preview": "vite preview",
		"test": "vitest run --config vitest.config.ts",
		"typecheck": "tsc --noEmit --composite false --declaration false --declarationMap false --emitDeclarationOnly false"
	},
	"dependencies": {
		"@tldraw/tlschema": "^5.1.1",
		"express": "^5.2.1",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"tldraw": "^5.1.1",
		"zod": "^4.1.8"
	},
	"devDependencies": {
		"@electron-forge/cli": "^7.11.2",
		"@electron-forge/maker-deb": "^7.11.2",
		"@electron-forge/maker-squirrel": "^7.11.2",
		"@electron-forge/maker-zip": "^7.11.2",
		"@types/express": "^5.0.6",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/supertest": "^7.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^10.0.3",
		"electron": "^42.4.1",
		"esbuild": "^0.28.1",
		"supertest": "^7.2.2",
		"tsx": "^4.22.4",
		"typescript": "^5.8.3",
		"vite": "^8.0.1",
		"vitest": "^4.1.9"
	}
}
