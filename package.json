{
	"name": "localart-canvas",
	"version": "0.0.0",
	"private": true,
	"homepage": "https://github.com/planedob/localart-canvas",
	"license": "MIT",
	"author": "LocalArt Canvas contributors",
	"engines": {
		"node": ">=22.15.0"
	},
	"type": "module",
	"scripts": {
		"build": "vite build && npm run typecheck",
		"dev": "concurrently -k -n server,client \"npm:dev:server\" \"npm:dev:client\"",
		"dev:client": "vite --host 127.0.0.1",
		"dev:server": "tsx watch server/index.ts",
		"preview": "vite preview",
		"test": "vitest run --config vitest.config.ts",
		"typecheck": "tsc --noEmit --composite false --declaration false --declarationMap false --emitDeclarationOnly false"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^2.0.2",
		"@ai-sdk/google": "^2.0.14",
		"@ai-sdk/openai": "^2.0.24",
		"@cloudflare/vite-plugin": "^1.29.1",
		"@google/generative-ai": "^0.24.1",
		"@tldraw/tlschema": "^5.1.1",
		"@worker-tools/json-stream": "^0.1.0-pre.12",
		"ai": "^5.0.63",
		"best-effort-json-parser": "^1.1.3",
		"express": "^5.2.1",
		"itty-router": "^5.0.18",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"react-markdown": "^10.1.0",
		"tldraw": "^5.1.1",
		"wrangler": "^4.75.0",
		"zod": "^4.1.8"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260302.0",
		"@types/express": "^5.0.6",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/supertest": "^7.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^10.0.3",
		"supertest": "^7.2.2",
		"tsx": "^4.22.4",
		"typescript": "^5.8.3",
		"vite": "^8.0.1",
		"vitest": "^4.1.9"
	}
}
